{
  "@context": ["dtmi:dtdl:context;3", "dtmi:fish:context;1"],
  "@id": "dtmi:fish:node;1",
  "@type": "Interface",
  "displayName": "FISH Node (N)",
  "description": "A rclcpp::Node or rclpy.Node — owns entities (subs, services, timers, clients, publishers). Subtypes (rclcpp_node, rclpy_node, container_manager) extend this Interface and add language- or framework-specific Properties / Telemetry.",

  "contents": [
    {"@type": "Property", "name": "node_handle",  "schema": "string"},
    {"@type": "Property", "name": "full_name",    "schema": "string"},
    {"@type": "Property", "name": "namespace",    "schema": "string"},
    {"@type": "Property", "name": "name",         "schema": "string"},
    {"@type": "Property", "name": "node_kind",    "schema": "string"},
    {"@type": "Property", "name": "init_ts_ns",   "schema": "long"},
    {"@type": "Property", "name": "source_file",  "schema": "string"},

    {
      "@type": ["Telemetry", "fish:Event"],
      "name": "node_init_event",
      "schema": "string",
      "description": "ros2:rcl_node_init event for this Node — captures pid, name, namespace, node_handle at construction.",
      "fish:source": "lttng",
      "fish:table": "ros2_trace",
      "fish:column": "payload",
      "fish:eventName": "ros2:rcl_node_init",
      "fish:filter": {"session_id": "{session_id}", "event": "ros2:rcl_node_init", "payload->>node_handle": "{node_handle}"},
      "fish:recommendedViz": "stat"
    },
    {
      "@type": ["Telemetry", "fish:Snapshot"],
      "name": "node_endpoints_for_this_node",
      "schema": "string",
      "description": "All endpoints (sub/pub/srv/cli/action) declared by this Node, joined to topic_info for message type + counts.",
      "fish:source": "ros2_cli",
      "fish:table": "node_endpoints",
      "fish:column": "topic_or_service",
      "fish:eventName": "ros2 node info",
      "fish:filter": {"session_id": "{session_id}", "node_full_name": "{full_name}"},
      "fish:recommendedViz": "stat"
    },

    {
      "@type": "Relationship", "name": "has_entity",
      "target": "dtmi:fish:entity;1",
      "minMultiplicity": 0
    }
  ]
}
