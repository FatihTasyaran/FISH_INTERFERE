{
  "@context": ["dtmi:dtdl:context;3", "dtmi:fish:context;1"],
  "@id": "dtmi:fish:session;1",
  "@type": "Interface",
  "displayName": "FISH Capture Session",
  "description": "A single FISH trace+profile run (LTTng ros2_tracing + nsys + /proc + ros2 CLI). Identified by session_id (e.g. 'fish_YYYYMMDD_HHMMSS' or 'dtdl_apriltag_<ts>') — the single tenancy key across every time-series and snapshot table in the `fish` PostgreSQL database.",

  "contents": [
    {"@type": "Property", "name": "session_id",     "schema": "string", "comment": "Primary key in sessions table — used in WHERE clauses for every session-scoped telemetry."},
    {"@type": "Property", "name": "session_dir",    "schema": "string", "comment": "Filesystem path to the captured session bundle (ros2/ + nsys/ + fishlog/ + snapshot/)."},
    {"@type": "Property", "name": "start_ts_ns",    "schema": "long"},
    {"@type": "Property", "name": "end_ts_ns",      "schema": "long"},
    {"@type": "Property", "name": "duration_ns",    "schema": "long"},
    {"@type": "Property", "name": "start_utc",      "schema": "string", "comment": "ISO-8601 UTC timestamp."},
    {"@type": "Property", "name": "fish_version",   "schema": "string"},
    {"@type": "Property", "name": "target_image",   "schema": "string"},
    {"@type": "Property", "name": "launch_script",  "schema": "string"},
    {"@type": "Property", "name": "tracepoint_set", "schema": "string"},
    {"@type": "Property", "name": "tracepoint_count","schema": "integer"},
    {"@type": "Property", "name": "nsys_flags",     "schema": "string"},
    {"@type": "Property", "name": "components_loaded","schema": "string", "comment": "JSON-encoded list of components loaded by ros2 component_container."},
    {"@type": "Property", "name": "gpu_model_name", "schema": "string"},
    {"@type": "Property", "name": "gpu_compute_capability","schema": "string"},
    {"@type": "Property", "name": "gpu_total_memory_bytes","schema": "long"},
    {"@type": "Property", "name": "gpu_sm_count",   "schema": "integer"},
    {"@type": "Property", "name": "gpu_uuid",       "schema": "string"},
    {"@type": "Property", "name": "fishlog_files",  "schema": "string"},

    {
      "@type": ["Telemetry", "fish:Event"],
      "name": "lttng_event_stream",
      "schema": "string",
      "description": "Raw LTTng ros2_trace event stream — primary FISH datapoint surface. Use sub-selectors (event, payload->>'...') to pull specific event types.",
      "fish:source": "lttng",
      "fish:table": "ros2_trace",
      "fish:column": "payload",
      "fish:eventName": "ros2:*",
      "fish:filter": {"session_id": "{session_id}"},
      "fish:recommendedViz": "timeline"
    },
    {
      "@type": ["Telemetry", "fish:Event"],
      "name": "daemon_events",
      "schema": "string",
      "description": "FISH daemon event log — stabilization, kill/resurrect, replay_start, gpu_handler, system_stable transitions.",
      "fish:source": "lttng",
      "fish:table": "fish_events",
      "fish:column": "cmd",
      "fish:eventName": "fish_daemon.*",
      "fish:filter": {"session_id": "{session_id}"},
      "fish:recommendedViz": "timeline"
    },
    {
      "@type": ["Telemetry", "fish:Snapshot"],
      "name": "node_info_collection",
      "schema": "string",
      "description": "All ros2 node info snapshots captured during the session.",
      "fish:source": "ros2_cli",
      "fish:table": "node_info",
      "fish:column": "node_full_name",
      "fish:eventName": "ros2 node info",
      "fish:filter": {"session_id": "{session_id}"},
      "fish:recommendedViz": "stat"
    },
    {
      "@type": ["Telemetry", "fish:Snapshot"],
      "name": "node_endpoints",
      "schema": "string",
      "description": "Normalized per-endpoint rows for every node (sub / pub / srv_server / srv_client / act_server / act_client → topic + msg_type).",
      "fish:source": "ros2_cli",
      "fish:table": "node_endpoints",
      "fish:column": "topic_or_service",
      "fish:filter": {"session_id": "{session_id}"},
      "fish:recommendedViz": "stat"
    },
    {
      "@type": ["Telemetry", "fish:Snapshot"],
      "name": "process_tree_snapshots",
      "schema": "string",
      "description": "Periodic /proc-derived process tree snapshots (PID/PPID/threads + CPU/mem).",
      "fish:source": "proc",
      "fish:table": "process_tree",
      "fish:column": "*",
      "fish:filter": {"session_id": "{session_id}"},
      "fish:recommendedViz": "timeline"
    },

    {
      "@type": "Relationship", "name": "runs_container",
      "target": "dtmi:fish:container;1",
      "minMultiplicity": 0
    },
    {
      "@type": "Relationship", "name": "has_executor",
      "target": "dtmi:fish:executor;1",
      "minMultiplicity": 1
    }
  ]
}
