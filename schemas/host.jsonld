{
  "@context": ["dtmi:dtdl:context;3", "dtmi:fish:context;1"],
  "@id": "dtmi:fish:host;1",
  "@type": "Interface",
  "displayName": "FISH Host",
  "description": "A physical machine that runs one or more FISH capture sessions. Top of the ownership hierarchy. Properties are stable across the host's lifetime; relationships fan out to sessions.",

  "contents": [
    {"@type": "Property", "name": "hostname",       "schema": "string"},
    {"@type": "Property", "name": "arch",           "schema": "string", "comment": "x86_64 | aarch64 | ..."},
    {"@type": "Property", "name": "kernel_version", "schema": "string"},
    {"@type": "Property", "name": "ros_distro",     "schema": "string", "comment": "humble | iron | jazzy"},
    {"@type": "Property", "name": "cpu_model",      "schema": "string"},
    {"@type": "Property", "name": "cpu_cores",      "schema": "integer"},
    {"@type": "Property", "name": "gpu_model",      "schema": "string"},
    {"@type": "Property", "name": "total_ram_kb",   "schema": "long"},

    {
      "@type": ["Telemetry", "fish:Snapshot"],
      "name": "host_registry",
      "schema": "string",
      "description": "Static host registry row keyed by hostname. One row per host across all sessions on this machine.",
      "fish:source": "proc",
      "fish:table": "hosts",
      "fish:column": "*",
      "fish:filter": {"host_name": "{hostname}"},
      "fish:recommendedViz": "stat"
    },

    {
      "@type": "Relationship", "name": "has_session",
      "target": "dtmi:fish:session;1",
      "minMultiplicity": 0
    }
  ]
}
