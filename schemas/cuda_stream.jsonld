{
  "@context": ["dtmi:dtdl:context;3", "dtmi:fish:context;1"],
  "@id": "dtmi:fish:cuda_stream;1",
  "@type": "Interface",
  "displayName": "FISH CUDA Stream",
  "description": "A CUDA stream created within an Executor process. First-class so dashboards can isolate stream-level concurrency / blocking patterns. Kernels reference their stream via the `gpu_kernel.on_stream` Relationship.",

  "contents": [
    {"@type": "Property", "name": "stream_handle", "schema": "string"},
    {"@type": "Property", "name": "owner_pid",     "schema": "integer"},
    {"@type": "Property", "name": "created_ts_ns", "schema": "long"},

    {
      "@type": ["Telemetry", "fish:Aggregated"],
      "name": "stream_busy_ns",
      "schema": "long",
      "description": "Time the stream was occupied by kernels (sum of kernel durations on this stream).",
      "fish:source": "cupti",
      "fish:table": "gpu_kernels",
      "fish:column": "duration_ns",
      "fish:filter": {"session_id": "{session_id}", "stream_id": "{stream_handle}"},
      "fish:recommendedViz": "stat",
      "fish:unit": "nanosecond"
    },
    {
      "@type": ["Telemetry", "fish:Event"],
      "name": "sync_events",
      "schema": "string",
      "description": "StreamWaitEvent / EventRecord activity on this stream.",
      "fish:source": "cupti",
      "fish:table": "gpu_sync",
      "fish:column": "sync_type",
      "fish:filter": {"session_id": "{session_id}", "stream_id": "{stream_handle}"},
      "fish:recommendedViz": "timeline"
    },
    {
      "@type": ["Telemetry", "fish:Snapshot"],
      "name": "stream_registry",
      "schema": "string",
      "description": "Static per-stream metadata captured from nsys CUDA_STREAM target table.",
      "fish:source": "cupti",
      "fish:table": "cuda_streams",
      "fish:column": "*",
      "fish:filter": {"session_id": "{session_id}", "stream_id": "{stream_handle}"},
      "fish:recommendedViz": "stat"
    }
  ]
}
