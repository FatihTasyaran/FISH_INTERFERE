{
  "@context": ["dtmi:dtdl:context;3", "dtmi:fish:context;1"],
  "@id": "dtmi:fish:executor;1",
  "@type": "Interface",
  "displayName": "FISH Executor (EX)",
  "description": "A process-bound ROS 2 executor. Identified by pid within the session.",

  "contents": [
    {"@type": "Property", "name": "pid",            "schema": "integer"},
    {"@type": "Property", "name": "tid",            "schema": "integer"},
    {"@type": "Property", "name": "executor_kind",  "schema": "string", "comment": "single_threaded | multi_threaded | static_single_threaded | rclpy"},
    {"@type": "Property", "name": "container_id",   "schema": "string"},
    {"@type": "Property", "name": "cmdline",        "schema": "string"},
    {"@type": "Property", "name": "started_ts_ns",  "schema": "long"},

    {
      "@type": ["Telemetry", "fish:Snapshot"],
      "name": "process_tree_row",
      "schema": "string",
      "description": "Process-tree snapshot row for this PID (PPID/threads/cmd).",
      "fish:source": "proc",
      "fish:table": "process_tree",
      "fish:column": "*",
      "fish:filter": {"session_id": "{session_id}", "pid": "{pid}"},
      "fish:recommendedViz": "stat"
    },
    {
      "@type": ["Telemetry", "fish:Snapshot"],
      "name": "thread_list",
      "schema": "string",
      "description": "Per-thread (LWP) rows for this PID.",
      "fish:source": "proc",
      "fish:table": "process_tree_threads",
      "fish:column": "lwp",
      "fish:filter": {"session_id": "{session_id}", "pid": "{pid}"},
      "fish:recommendedViz": "stat"
    },
    {
      "@type": ["Telemetry", "fish:Event"],
      "name": "spin_events",
      "schema": "string",
      "description": "fish_executor_spin / get_next_ready event stream for this process.",
      "fish:source": "lttng",
      "fish:table": "ros2_trace",
      "fish:column": "payload",
      "fish:eventName": "ros2:fish_executor_*",
      "fish:filter": {"session_id": "{session_id}", "vpid": "{pid}", "event~": "^ros2:fish_executor_"},
      "fish:recommendedViz": "timeline"
    },
    {
      "@type": ["Telemetry", "fish:Aggregated"],
      "name": "gpu_kernel_time_ns",
      "schema": "long",
      "description": "Sum of GPU kernel durations attributed to this process (via nsys-encoded global_pid → os_pid).",
      "fish:source": "cupti",
      "fish:table": "gpu_kernels",
      "fish:column": "duration_ns",
      "fish:filter": {"session_id": "{session_id}", "global_pid_decoded": "{pid}"},
      "fish:derivation": "((global_pid >> 24) & 0xFFFFFF) = {pid}",
      "fish:recommendedViz": "stat",
      "fish:unit": "nanosecond"
    },

    {
      "@type": "Relationship", "name": "has_node",
      "target": "dtmi:fish:node;1",
      "minMultiplicity": 1
    },
    {
      "@type": "Relationship", "name": "owns_stream",
      "target": "dtmi:fish:cuda_stream;1",
      "minMultiplicity": 0
    }
  ]
}
