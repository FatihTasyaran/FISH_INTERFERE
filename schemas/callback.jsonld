{
  "@context": ["dtmi:dtdl:context;3", "dtmi:fish:context;1"],
  "@id": "dtmi:fish:callback;1",
  "@type": "Interface",
  "displayName": "FISH Callback (F)",
  "description": "A first-class callback function bound to a ROS 2 entity. Carries the function symbol, source file/line, registration time, and primary live telemetry (duration distribution). Owns GPU kernels launched from inside it via the `launches` Relationship (if any).",

  "contents": [
    {"@type": "Property", "name": "cb_addr",            "schema": "string"},
    {"@type": "Property", "name": "symbol_demangled",   "schema": "string"},
    {"@type": "Property", "name": "symbol_mangled",     "schema": "string"},
    {"@type": "Property", "name": "source_file",        "schema": "string"},
    {"@type": "Property", "name": "source_line",        "schema": "integer"},
    {"@type": "Property", "name": "language",           "schema": "string"},
    {"@type": "Property", "name": "registered_ts_ns",   "schema": "long"},
    {"@type": "Property", "name": "owner_entity_handle","schema": "string"},

    {
      "@type": ["Telemetry", "fish:Duration"],
      "name": "callback_duration_ns",
      "schema": "long",
      "description": "Per-invocation wall-time duration. Derived from paired ros2:callback_start / ros2:callback_end events for this cb_addr.",
      "fish:source": "lttng",
      "fish:table": "ros2_trace",
      "fish:column": "ts_ns",
      "fish:eventName": "ros2:callback_start + ros2:callback_end",
      "fish:filter": {"session_id": "{session_id}", "payload->>callback": "{cb_addr}", "event_in": "['ros2:callback_start','ros2:callback_end']"},
      "fish:derivation": "LAG-window join: end.ts_ns - start.ts_ns over the start/end pair stream filtered by payload->>'callback' = {cb_addr}",
      "fish:recommendedViz": "histogram",
      "fish:unit": "nanosecond"
    },
    {
      "@type": ["Telemetry", "fish:Event"],
      "name": "callback_start_stream",
      "schema": "string",
      "description": "Raw callback_start event stream — used for timeline view + correlating with GPU launches via cuda_callchain.",
      "fish:source": "lttng",
      "fish:table": "ros2_trace",
      "fish:column": "payload",
      "fish:eventName": "ros2:callback_start",
      "fish:filter": {"session_id": "{session_id}", "event": "ros2:callback_start", "payload->>callback": "{cb_addr}"},
      "fish:recommendedViz": "timeline"
    },
    {
      "@type": ["Telemetry", "fish:Aggregated"],
      "name": "gpu_time_attributed_ns",
      "schema": "long",
      "description": "Aggregate GPU kernel time attributed to this callback by FISH's cuda_callchain bridge. Sum of gpu_kernels.duration_ns for kernels whose runtime call's callchain ties back to a callback_start window for this cb_addr.",
      "fish:source": "derived",
      "fish:table": "gpu_kernels",
      "fish:column": "duration_ns",
      "fish:filter": {"session_id": "{session_id}"},
      "fish:derivation": "Join gpu_kernels → cuda_runtime via correlation_id → cuda_callchain via callchain_id → ros2_trace callback_start by (vpid, ts_ns) bracket on payload->>'callback' = {cb_addr}",
      "fish:recommendedViz": "stat",
      "fish:unit": "nanosecond"
    },

    {
      "@type": "Relationship", "name": "launches",
      "target": "dtmi:fish:gpu_kernel;1",
      "minMultiplicity": 0,
      "comment": "Ownership: GPU kernels launched from inside this callback (zero for non-GPU callbacks; many for ML inference / image-pipeline callbacks)."
    }
  ]
}
