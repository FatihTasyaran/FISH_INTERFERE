{
  "@context": ["dtmi:dtdl:context;3", "dtmi:fish:context;1"],
  "@id": "dtmi:fish:container;1",
  "@type": "Interface",
  "displayName": "FISH Container",
  "description": "A Docker/Podman container scoped to one session. Hosts one or more executors.",

  "contents": [
    {"@type": "Property", "name": "container_id",   "schema": "string"},
    {"@type": "Property", "name": "container_name", "schema": "string"},
    {"@type": "Property", "name": "image_tag",      "schema": "string"},
    {"@type": "Property", "name": "image_hash",     "schema": "string"},
    {"@type": "Property", "name": "started_ts_ns",  "schema": "long"},

    {
      "@type": ["Telemetry", "fish:Aggregated"],
      "name": "container_gpu_kernel_time_ns",
      "schema": "long",
      "description": "Sum of GPU kernel durations attributed to this container.",
      "fish:source": "cupti",
      "fish:table": "gpu_kernels",
      "fish:column": "duration_ns",
      "fish:filter": {"session_id": "{session_id}", "container": "{container_name}"},
      "fish:recommendedViz": "stat",
      "fish:unit": "nanosecond"
    },

    {
      "@type": "Relationship", "name": "hosts_executor",
      "target": "dtmi:fish:executor;1",
      "minMultiplicity": 1
    }
  ]
}
