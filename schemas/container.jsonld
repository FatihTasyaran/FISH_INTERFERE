{
  "@context": ["dtmi:dtdl:context;3", "dtmi:fish:context;1"],
  "@id": "dtmi:fish:container;1",
  "@type": "Interface",
  "displayName": "FISH Container",
  "description": "A Docker/Podman container scoped to one session. Hosts one or more executors. Image identity is captured via image_tag + image_hash.",

  "contents": [
    {"@type": "Property", "name": "container_id",   "schema": "string"},
    {"@type": "Property", "name": "container_name", "schema": "string"},
    {"@type": "Property", "name": "image_tag",      "schema": "string"},
    {"@type": "Property", "name": "image_hash",     "schema": "string"},
    {"@type": "Property", "name": "started_ts_ns",  "schema": "long"},

    {
      "@type": ["Telemetry", "fish:Sampled"],
      "name": "container_cpu_pct",
      "schema": "double",
      "fish:source": "proc",
      "fish:store": "mongodb",
      "fish:dbName": "{session_id}",
      "fish:collection": "process_tree",
      "fish:fieldName": "per_container.cpu_pct",
      "fish:tagSelector": {"container_id": "{container_id}"},
      "fish:recommendedViz": "timeseries",
      "fish:unit": "percent"
    },
    {
      "@type": ["Telemetry", "fish:Sampled"],
      "name": "container_mem_rss_kb",
      "schema": "long",
      "fish:source": "proc",
      "fish:store": "mongodb",
      "fish:dbName": "{session_id}",
      "fish:collection": "process_tree",
      "fish:fieldName": "per_container.rss_kb",
      "fish:tagSelector": {"container_id": "{container_id}"},
      "fish:recommendedViz": "timeseries",
      "fish:unit": "kibibyte"
    },

    {
      "@type": "Relationship", "name": "hosts_executor",
      "target": "dtmi:fish:executor;1",
      "minMultiplicity": 1
    }
  ]
}
