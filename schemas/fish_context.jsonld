{
  "_comment": "FISH DTDL extension context — adds telemetry-pointer fields so each Interface carries the explicit location of its live data in the single PostgreSQL+TimescaleDB backend. Originally inspired by P-MoVE's PMUName/SamplerName/DBName/FieldName encoding (P-MoVE paper §III.B, Listing 1) and FISH's earlier two-store (Mongo+Influx) architecture. After the 2026-06-16 migration to a single PG backend, the store/collection/measurement split was collapsed into one fish:table + fish:column + fish:filter triple. dtmi:fish:context;1.",

  "@context": {
    "@version": 1.1,
    "fish": "https://github.com/FatihTasyaran/FISH_INTERFERE/schemas#",

    "fish:source": {
      "@id": "fish:source",
      "@type": "@vocab",
      "_comment": "Datapoint origin. Values: lttng | cupti | proc | ros2_cli | dcgm | derived | snapshot"
    },
    "fish:table": {
      "@id": "fish:table",
      "@type": "xsd:string",
      "_comment": "PostgreSQL table name (always in the `fish` database). See scripts/init_fish_pg.sql for the canonical schema."
    },
    "fish:column": {
      "@id": "fish:column",
      "@type": "xsd:string",
      "_comment": "Value column for the telemetry — typed PG column for time-series tables (e.g. duration_ns), or a JSONB path like 'payload->>callback' for structured columns."
    },
    "fish:filter": {
      "@id": "fish:filter",
      "@container": "@index",
      "_comment": "WHERE-clause filter: {column: value-or-placeholder}. Placeholders like '{cb_addr}', '{session_id}', '{kernel_name}', '{stream_handle}' are resolved against the instance Interface's Properties at query time. Values that name JSONB paths use the PG '->>'/'->' operator syntax (e.g. \"payload->>'callback'\" as the key)."
    },
    "fish:eventName": {
      "@id": "fish:eventName",
      "@type": "xsd:string",
      "_comment": "Origin event identifier for documentation — LTTng event name (e.g. 'ros2:callback_start'), CUPTI activity kind, /proc field, or ros2 CLI command. Resolved at query time when relevant (e.g. ros2_trace lookups also filter by `event` column)."
    },
    "fish:recommendedViz": {
      "@id": "fish:recommendedViz",
      "@type": "@vocab",
      "_comment": "Panel-factory hint. Values: timeseries | heatmap | stat | timeline | histogram | roofline | bargauge"
    },
    "fish:unit": {
      "@id": "fish:unit",
      "@type": "xsd:string",
      "_comment": "Physical unit. Values: nanosecond | microsecond | millisecond | byte | kibibyte | mebibyte | hertz | percent | count | bit"
    },
    "fish:derivation": {
      "@id": "fish:derivation",
      "@type": "xsd:string",
      "_comment": "For fish:source = derived: a short expression naming the source telemetries and the transform (e.g. a SQL window function or pre-computed JOIN). The on-demand builder may rewrite this as a CTE or a materialized continuous aggregate."
    },

    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },

  "@id": "dtmi:fish:context;1",
  "@type": "Context",
  "displayName": "FISH telemetry-pointer extension to DTDL v3 (PostgreSQL backend)",
  "version": 2,
  "specifies": [
    "fish:source", "fish:table", "fish:column", "fish:filter",
    "fish:eventName", "fish:recommendedViz", "fish:unit", "fish:derivation"
  ]
}
