{
  "_comment": "FISH DTDL extension context — adds telemetry pointer fields so each Interface carries the location of its live data. Inspired by P-MoVE's PMUName/SamplerName/DBName/FieldName encoding on Telemetry entries (P-MoVE paper Fig. 1 + Section III.B), generalized to FISH's two-store (MongoDB + InfluxDB) reality. Reference @id: dtmi:fish:context;1",

  "@context": {
    "@version": 1.1,
    "fish": "https://github.com/FatihTasyaran/FISH_INTERFERE/schemas#",

    "fish:source": {
      "@id": "fish:source",
      "@type": "@vocab",
      "_comment": "Datapoint origin. Values: lttng | cupti | proc | ros2_cli | dcgm | derived"
    },
    "fish:store": {
      "@id": "fish:store",
      "@type": "@vocab",
      "_comment": "Backing store. Values: mongodb | influxdb. LTTng ros2_trace lives in MongoDB (timeseries collection); CUPTI/nsys data lives in InfluxDB."
    },
    "fish:dbName": {
      "@id": "fish:dbName",
      "@type": "xsd:string",
      "_comment": "Database name. For session-scoped data: '{session_id}' literal placeholder (resolved at query time). For shared GPU data: 'fish'."
    },
    "fish:collection": {
      "@id": "fish:collection",
      "@type": "xsd:string",
      "_comment": "MongoDB collection name (when fish:store = mongodb)."
    },
    "fish:measurement": {
      "@id": "fish:measurement",
      "@type": "xsd:string",
      "_comment": "InfluxDB measurement name (when fish:store = influxdb)."
    },
    "fish:fieldName": {
      "@id": "fish:fieldName",
      "@type": "xsd:string",
      "_comment": "Field name (InfluxDB) or document path (MongoDB) for the actual value."
    },
    "fish:eventName": {
      "@id": "fish:eventName",
      "@type": "xsd:string",
      "_comment": "Origin event identifier — LTTng event name (e.g. 'ros2:callback_start'), CUPTI activity kind, /proc field, or ros2 CLI command."
    },
    "fish:tagSelector": {
      "@id": "fish:tagSelector",
      "@container": "@index",
      "_comment": "Filter expression: {tag_key: value}. Values can be literals or instance-property references using '{property_name}' placeholders (e.g. '{cb_addr}', '{kernel_name}', '{pid}'). The on-demand builder resolves placeholders against the instance Interface's Properties at query time."
    },
    "fish:recommendedViz": {
      "@id": "fish:recommendedViz",
      "@type": "@vocab",
      "_comment": "Hint for the panel factory. Values: timeseries | heatmap | stat | timeline | histogram | roofline | bargauge"
    },
    "fish:unit": {
      "@id": "fish:unit",
      "@type": "xsd:string",
      "_comment": "Physical unit. Values: nanosecond | microsecond | millisecond | byte | kibibyte | mebibyte | hertz | percent | count | bit"
    },
    "fish:derivation": {
      "@id": "fish:derivation",
      "@type": "xsd:string",
      "_comment": "For fish:source = derived: a short expression naming the source telemetry and the transform (e.g. 'callback_end.ts - callback_start.ts')."
    },

    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },

  "@id": "dtmi:fish:context;1",
  "@type": "Context",
  "displayName": "FISH telemetry-pointer extension to DTDL v3",
  "version": 1,
  "specifies": [
    "fish:source", "fish:store", "fish:dbName", "fish:collection",
    "fish:measurement", "fish:fieldName", "fish:eventName",
    "fish:tagSelector", "fish:recommendedViz", "fish:unit", "fish:derivation"
  ]
}
