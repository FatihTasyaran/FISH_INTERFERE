{
  "@context": ["dtmi:dtdl:context;3", "dtmi:fish:context;1"],
  "@id": "dtmi:fish:gpu_kernel;1",
  "@type": "Interface",
  "displayName": "FISH GPU Kernel",
  "description": "A CUDA kernel observed in this session. Each unique kernel_name within a session yields a separate instance (matching P-MoVE's per-component instancing pattern). Bound to its owning Callback (via the callback.launches Relationship) and the CUDA Stream(s) it ran on (`on_stream` Relationship).",

  "contents": [
    {"@type": "Property", "name": "kernel_name",     "schema": "string"},
    {"@type": "Property", "name": "kernel_signature","schema": "string"},
    {"@type": "Property", "name": "grid_dim",        "schema": "string"},
    {"@type": "Property", "name": "block_dim",       "schema": "string"},
    {"@type": "Property", "name": "registers_per_thread","schema": "integer"},
    {"@type": "Property", "name": "static_smem_bytes","schema": "long"},
    {"@type": "Property", "name": "dynamic_smem_bytes","schema": "long"},
    {"@type": "Property", "name": "first_launch_ts_ns","schema": "long"},

    {
      "@type": ["Telemetry", "fish:Duration"],
      "name": "kernel_duration_ns",
      "schema": "long",
      "description": "Per-launch GPU execution time for this kernel.",
      "fish:source": "cupti",
      "fish:table": "gpu_kernels",
      "fish:column": "duration_ns",
      "fish:eventName": "CUPTI_ACTIVITY_KIND_KERNEL",
      "fish:filter": {"session_id": "{session_id}", "kernel_name": "{kernel_name}"},
      "fish:recommendedViz": "histogram",
      "fish:unit": "nanosecond"
    },
    {
      "@type": ["Telemetry", "fish:Aggregated"],
      "name": "launch_count",
      "schema": "long",
      "description": "Number of launches of this kernel in the session.",
      "fish:source": "cupti",
      "fish:table": "gpu_kernels",
      "fish:column": "count(*)",
      "fish:filter": {"session_id": "{session_id}", "kernel_name": "{kernel_name}"},
      "fish:recommendedViz": "stat",
      "fish:unit": "count"
    },
    {
      "@type": ["Telemetry", "fish:Aggregated"],
      "name": "memcpy_bytes_on_stream",
      "schema": "long",
      "description": "Memory transferred on the same stream(s) this kernel ran on (host↔device).",
      "fish:source": "cupti",
      "fish:table": "gpu_memcpy",
      "fish:column": "bytes",
      "fish:eventName": "CUPTI_ACTIVITY_KIND_MEMCPY",
      "fish:filter": {"session_id": "{session_id}", "stream_id": "{stream_handle}"},
      "fish:recommendedViz": "timeseries",
      "fish:unit": "byte"
    },

    {
      "@type": "Relationship", "name": "on_stream",
      "target": "dtmi:fish:cuda_stream;1",
      "minMultiplicity": 1,
      "comment": "Reference to the stream(s) this kernel ran on across the session."
    }
  ]
}
