{
  "@context": ["dtmi:dtdl:context;3", "dtmi:fish:context;1"],
  "@id": "dtmi:fish:gpu_kernel;1",
  "@type": "Interface",
  "displayName": "FISH GPU Kernel",
  "description": "A CUDA kernel observed in this session. Each unique (kernel_name, launch_site) yields a separate instance — matching P-MoVE's per-component instancing pattern. Bound to its owning Callback (via the callback.launches Relationship) and the CUDA Stream it ran on (`on_stream` Relationship).",

  "contents": [
    {"@type": "Property", "name": "kernel_name",     "schema": "string", "comment": "Demangled kernel name."},
    {"@type": "Property", "name": "kernel_signature","schema": "string", "comment": "Full mangled signature for unique disambiguation."},
    {"@type": "Property", "name": "grid_dim",        "schema": "string", "comment": "e.g. (256,1,1)"},
    {"@type": "Property", "name": "block_dim",       "schema": "string"},
    {"@type": "Property", "name": "registers_per_thread","schema": "integer"},
    {"@type": "Property", "name": "static_smem_bytes","schema": "long"},
    {"@type": "Property", "name": "dynamic_smem_bytes","schema": "long"},
    {"@type": "Property", "name": "first_launch_ts_ns","schema": "long"},

    {
      "@type": ["Telemetry", "fish:Duration"],
      "name": "kernel_duration_ns",
      "schema": "long",
      "description": "Per-launch GPU execution time for this kernel.",
      "fish:source": "cupti",
      "fish:store": "influxdb",
      "fish:dbName": "fish",
      "fish:measurement": "gpu_kernels",
      "fish:fieldName": "duration_ns",
      "fish:eventName": "CUPTI_ACTIVITY_KIND_KERNEL",
      "fish:tagSelector": {"session": "{session_id}", "kernel_name": "{kernel_name}"},
      "fish:recommendedViz": "histogram",
      "fish:unit": "nanosecond"
    },
    {
      "@type": ["Telemetry", "fish:Aggregated"],
      "name": "launch_count",
      "schema": "long",
      "description": "Number of launches of this kernel in the session.",
      "fish:source": "cupti",
      "fish:store": "influxdb",
      "fish:dbName": "fish",
      "fish:measurement": "gpu_kernels",
      "fish:fieldName": "count(*)",
      "fish:tagSelector": {"session": "{session_id}", "kernel_name": "{kernel_name}"},
      "fish:recommendedViz": "stat",
      "fish:unit": "count"
    },
    {
      "@type": ["Telemetry", "fish:Aggregated"],
      "name": "memcpy_bytes",
      "schema": "long",
      "description": "Memory transferred near this kernel's launches (host↔device). Correlated by correlationId proximity.",
      "fish:source": "cupti",
      "fish:store": "influxdb",
      "fish:dbName": "fish",
      "fish:measurement": "gpu_memcpy",
      "fish:fieldName": "bytes",
      "fish:eventName": "CUPTI_ACTIVITY_KIND_MEMCPY",
      "fish:tagSelector": {"session": "{session_id}", "streamId": "{stream_handle}"},
      "fish:recommendedViz": "timeseries",
      "fish:unit": "byte"
    },

    {
      "@type": "Relationship", "name": "on_stream",
      "target": "dtmi:fish:cuda_stream;1",
      "minMultiplicity": 1,
      "comment": "Reference (not ownership) to the stream(s) this kernel ran on. A kernel may run on multiple streams across the session — each is listed."
    }
  ]
}
