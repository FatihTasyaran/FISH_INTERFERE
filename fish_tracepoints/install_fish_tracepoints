    ctf_integer_hex(const void *, callback, callback_arg)
    ctf_string(symbol, symbol_arg)
  )
)

"""
    content = content.replace(INSERT_BEFORE, new_events + INSERT_BEFORE)
    with open(path, "w") as f:
        f.write(content)
    print("    tp_call.h patched")

# ── tracetools.h ──
path = f"{OVERLAY}/include/tracetools/tracetools.h"
with open(path) as f:
    content = f.read()

if "fish_rclpy_subscription_callback_added" in content:
    print("    tracetools.h already has rclpy events, skipping")
else:
    INSERT_BEFORE = "#ifdef __cplusplus\n}\n#endif\n\n#endif  // TRACETOOLS__TRACETOOLS_H_"
    new_decls = """/// `fish_rclpy_subscription_callback_added`
