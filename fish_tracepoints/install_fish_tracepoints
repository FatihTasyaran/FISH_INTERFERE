#!/bin/bash
# =============================================================================
# FISH Tracepoint Installer
# =============================================================================
# Installs custom LTTng tracepoints for ROS 2 into an overlay workspace.
#
# Features:
#   --action  4 action server dispatch tracepoints (rclcpp_action C++ patches)
#   --rclpy   5 rclpy callback chain tracepoints (ctypes bridge + Python patches)
#   --all     Both (default if no flag given)
#
# Target: ROS 2 Humble
# Packages: tracetools 4.1.2, rclcpp 16.0.19, rcl 5.3.12
#
# Usage:
#   ./install_fish_tracepoints [--action] [--rclpy] [--all] [--help]
#
# After installation, source the overlay before launching ROS nodes:
#   source /root/trace_overlay_ws/install/setup.bash
# =============================================================================
set -euo pipefail

# ─── Argument parsing ────────────────────────────────────────────────────────
DO_ACTION=false
DO_RCLPY=false
DO_CLIENT=false
DO_LINK=false
DO_SCHEDULER=false

if [ $# -eq 0 ]; then
    DO_ACTION=true
    DO_RCLPY=true
    DO_CLIENT=true
    DO_LINK=true
    DO_SCHEDULER=true
fi

while [ $# -gt 0 ]; do
    case "$1" in
        --action)    DO_ACTION=true ;;
        --rclpy)     DO_RCLPY=true ;;
        --client)    DO_CLIENT=true ;;
        --link)      DO_LINK=true ;;
        --scheduler) DO_SCHEDULER=true ;;
        --all)       DO_ACTION=true; DO_RCLPY=true; DO_CLIENT=true; DO_LINK=true; DO_SCHEDULER=true ;;
        --help|-h)
            echo "Usage: $0 [--action] [--rclpy] [--client] [--link] [--scheduler] [--all] [--help]"
            echo ""
            echo "  --action     Install 4 action server dispatch tracepoints"
            echo "  --rclpy      Install 5 rclpy callback chain tracepoints"
            echo "  --client     Install 2 service client tracepoints"
            echo "  --link       Install 2 callback-link tracepoints (fish_rclcpp_publish_link, fish_rclcpp_client_link)"
            echo "  --scheduler  Install 4 scheduler introspection tracepoints (executor/cbgroup)"
            echo "  --all        Install all (default if no flag given)"
            exit 0
            ;;
        *)
            echo "Unknown option: $1" >&2
            echo "Run $0 --help for usage" >&2
            exit 1
            ;;
    esac
    shift
done

# ─── Configuration ───────────────────────────────────────────────────────────
OVERLAY_WS="${OVERLAY_WS:-/root/trace_overlay_ws}"
TRACETOOLS_TAG="${TRACETOOLS_TAG:-4.1.2}"
RCLCPP_TAG="${RCLCPP_TAG:-16.0.19}"
RCL_TAG="${RCL_TAG:-5.3.12}"
CLONE_DIR="/tmp/fish_tracepoint_src"
RCLPY_DIR="/opt/ros/humble/local/lib/python3.10/dist-packages/rclpy"

# ─── Utility functions ───────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

STEP=0
log()  { echo -e "${GREEN}[FISH]${NC} $*"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $*"; }
err()  { echo -e "${RED}[ERR]${NC} $*" >&2; }
step() { STEP=$((STEP + 1)); log "[$STEP] $*"; }

clone_if_needed() {
    local repo=$1 tag=$2 dir=$3
    if [ -d "$dir" ]; then
        log "  $dir already exists, skipping clone"
    else
        log "  Cloning $repo @ $tag ..."
        git clone --depth 1 --branch "$tag" "$repo" "$dir" 2>&1 | tail -1
    fi
}

# ─── Pre-flight checks ──────────────────────────────────────────────────────
preflight_checks() {
    if [ ! -f /opt/ros/humble/setup.bash ]; then
        err "ROS 2 Humble not found at /opt/ros/humble. Aborting."
        exit 1
    fi
    set +u && source /opt/ros/humble/setup.bash && set -u

    command -v colcon >/dev/null 2>&1 || {
        err "colcon not found. Install: apt install python3-colcon-common-extensions"
        exit 1
    }
    command -v git >/dev/null 2>&1 || {
        err "git not found. Install: apt install git"
        exit 1
    }
    if $DO_RCLPY && [ ! -d "$RCLPY_DIR" ]; then
        err "rclpy not found at $RCLPY_DIR. Aborting."
        exit 1
    fi

    if ! python3 -c "import tracetools_trace" 2>/dev/null; then
        err "tracetools_trace not found. FISH requires it for ros2 trace."
        err "Install: apt install -y ros-humble-tracetools-trace ros-humble-ros2trace"
        exit 1
    fi
}

# ─── Workspace + clone functions ────────────────────────────────────────────
create_workspace() {
    step "Creating overlay workspace at $OVERLAY_WS ..."
    mkdir -p "$OVERLAY_WS/src"
}

clone_repos() {
    step "Cloning source repositories ..."
    mkdir -p "$CLONE_DIR"

    clone_if_needed \
        "https://github.com/ros2/ros2_tracing.git" \
        "$TRACETOOLS_TAG" "$CLONE_DIR/ros2_tracing"

    if $DO_ACTION || $DO_CLIENT || $DO_SCHEDULER; then
        clone_if_needed \
            "https://github.com/ros2/rclcpp.git" \
            "$RCLCPP_TAG" "$CLONE_DIR/rclcpp"
    fi
    if $DO_ACTION || $DO_LINK; then
        clone_if_needed \
            "https://github.com/ros2/rcl.git" \
            "$RCL_TAG" "$CLONE_DIR/rcl"
    fi
}

copy_sources() {
    step "Copying packages into workspace ..."

    # Always need tracetools (fresh copy for clean patching)
    if [ -d "$OVERLAY_WS/src/tracetools" ]; then
        warn "  $OVERLAY_WS/src/tracetools exists, removing for clean state"
        rm -rf "$OVERLAY_WS/src/tracetools"
    fi
    cp -r "$CLONE_DIR/ros2_tracing/tracetools" "$OVERLAY_WS/src/tracetools"

    if $DO_ACTION; then
        if [ -d "$OVERLAY_WS/src/rclcpp_action" ]; then
            warn "  $OVERLAY_WS/src/rclcpp_action exists, removing for clean state"
            rm -rf "$OVERLAY_WS/src/rclcpp_action"
        fi
        cp -r "$CLONE_DIR/rclcpp/rclcpp_action" "$OVERLAY_WS/src/rclcpp_action"
        cp "$CLONE_DIR/rcl/rcl_action/src/rcl_action/action_server_impl.h" \
           "$OVERLAY_WS/src/rclcpp_action/src/action_server_impl.h"
        log "  Copied action_server_impl.h from rcl source"
    fi

    if $DO_LINK; then
        if [ -d "$OVERLAY_WS/src/rcl" ]; then
            warn "  $OVERLAY_WS/src/rcl exists, removing for clean state"
            rm -rf "$OVERLAY_WS/src/rcl"
        fi
        cp -r "$CLONE_DIR/rcl/rcl" "$OVERLAY_WS/src/rcl"
        log "  Copied rcl into workspace (for publish/client fire points)"
    fi

    # rclcpp source — wipe+copy so any previous-patched source (with old
    # tracepoint names) is discarded. Required after the fish_<layer>_<name>
    # rename: image build may have patched rclcpp with the old names.
    if $DO_CLIENT || $DO_SCHEDULER; then
        if [ -d "$OVERLAY_WS/src/rclcpp" ]; then
            warn "  $OVERLAY_WS/src/rclcpp exists, removing for clean state"
            rm -rf "$OVERLAY_WS/src/rclcpp"
        fi
        cp -r "$CLONE_DIR/rclcpp/rclcpp" "$OVERLAY_WS/src/rclcpp"
        log "  Copied rclcpp into workspace (for client + scheduler patches)"
    fi
}

# ─── Tracetools C patches ───────────────────────────────────────────────────
patch_tracetools_action() {
    log "  Patching tracetools for action server tracepoints ..."
    cd "$OVERLAY_WS/src/tracetools"

    # --- tp_call.h ---
    patch -p1 --forward --no-backup-if-mismatch <<'PATCH_TP_CALL' || true
--- a/include/tracetools/tp_call.h
+++ b/include/tracetools/tp_call.h
@@ -408,6 +408,58 @@
   )
 )

+TRACEPOINT_EVENT(
+  TRACEPOINT_PROVIDER,
+  fish_rclcpp_action_server_init,
+  TP_ARGS(
+    const void *, action_server_handle_arg,
+    const char *, action_name_arg,
+    const void *, goal_service_handle_arg,
+    const void *, cancel_service_handle_arg,
+    const void *, result_service_handle_arg
+  ),
+  TP_FIELDS(
+    ctf_integer_hex(const void *, action_server_handle, action_server_handle_arg)
+    ctf_string(action_name, action_name_arg)
+    ctf_integer_hex(const void *, goal_service_handle, goal_service_handle_arg)
+    ctf_integer_hex(const void *, cancel_service_handle, cancel_service_handle_arg)
+    ctf_integer_hex(const void *, result_service_handle, result_service_handle_arg)
+  )
+)
+
+TRACEPOINT_EVENT(
+  TRACEPOINT_PROVIDER,
+  fish_rclcpp_action_execute_goal,
+  TP_ARGS(
+    const void *, action_server_handle_arg
+  ),
+  TP_FIELDS(
+    ctf_integer_hex(const void *, action_server_handle, action_server_handle_arg)
+  )
+)
+
+TRACEPOINT_EVENT(
+  TRACEPOINT_PROVIDER,
+  fish_rclcpp_action_execute_cancel,
+  TP_ARGS(
+    const void *, action_server_handle_arg
+  ),
+  TP_FIELDS(
+    ctf_integer_hex(const void *, action_server_handle, action_server_handle_arg)
+  )
+)
+
+TRACEPOINT_EVENT(
+  TRACEPOINT_PROVIDER,
+  fish_rclcpp_action_execute_result,
+  TP_ARGS(
+    const void *, action_server_handle_arg
+  ),
+  TP_FIELDS(
+    ctf_integer_hex(const void *, action_server_handle, action_server_handle_arg)
+  )
+)
+
 #endif  // _TRACETOOLS__TP_CALL_H_

 #include <lttng/tracepoint-event.h>
PATCH_TP_CALL
    log "    tp_call.h patched"

    # --- tracetools.h ---
    patch -p1 --forward --no-backup-if-mismatch <<'PATCH_TT_H' || true
--- a/include/tracetools/tracetools.h
+++ b/include/tracetools/tracetools.h
@@ -482,6 +482,55 @@
   rclcpp_executor_execute,
   const void * handle)

+/// `fish_rclcpp_action_server_init`
+/**
+ * Initialization of an action server.
+ * Links the action server handle to its name and component service handles.
+ *
+ * \param[in] action_server_handle pointer to the rcl_action_server_t
+ * \param[in] action_name the name of the action
+ * \param[in] goal_service_handle pointer to the goal service
+ * \param[in] cancel_service_handle pointer to the cancel service
+ * \param[in] result_service_handle pointer to the result service
+ */
+DECLARE_TRACEPOINT(
+  fish_rclcpp_action_server_init,
+  const void * action_server_handle,
+  const char * action_name,
+  const void * goal_service_handle,
+  const void * cancel_service_handle,
+  const void * result_service_handle)
+
+/// `fish_rclcpp_action_execute_goal`
+/**
+ * Start of action goal request dispatch.
+ *
+ * \param[in] action_server_handle pointer to the rcl_action_server_t
+ */
+DECLARE_TRACEPOINT(
+  fish_rclcpp_action_execute_goal,
+  const void * action_server_handle)
+
+/// `fish_rclcpp_action_execute_cancel`
+/**
+ * Start of action cancel request dispatch.
+ *
+ * \param[in] action_server_handle pointer to the rcl_action_server_t
+ */
+DECLARE_TRACEPOINT(
+  fish_rclcpp_action_execute_cancel,
+  const void * action_server_handle)
+
+/// `fish_rclcpp_action_execute_result`
+/**
+ * Start of action result request dispatch.
+ *
+ * \param[in] action_server_handle pointer to the rcl_action_server_t
+ */
+DECLARE_TRACEPOINT(
+  fish_rclcpp_action_execute_result,
+  const void * action_server_handle)
+
 #ifdef __cplusplus
 }
 #endif
PATCH_TT_H
    log "    tracetools.h patched"

    # --- tracetools.c ---
    patch -p1 --forward --no-backup-if-mismatch <<'PATCH_TT_C' || true
--- a/src/tracetools.c
+++ b/src/tracetools.c
@@ -362,6 +362,50 @@
     handle);
 }

+void TRACEPOINT(
+  fish_rclcpp_action_server_init,
+  const void * action_server_handle,
+  const char * action_name,
+  const void * goal_service_handle,
+  const void * cancel_service_handle,
+  const void * result_service_handle)
+{
+  CONDITIONAL_TP(
+    fish_rclcpp_action_server_init,
+    action_server_handle,
+    action_name,
+    goal_service_handle,
+    cancel_service_handle,
+    result_service_handle);
+}
+
+void TRACEPOINT(
+  fish_rclcpp_action_execute_goal,
+  const void * action_server_handle)
+{
+  CONDITIONAL_TP(
+    fish_rclcpp_action_execute_goal,
+    action_server_handle);
+}
+
+void TRACEPOINT(
+  fish_rclcpp_action_execute_cancel,
+  const void * action_server_handle)
+{
+  CONDITIONAL_TP(
+    fish_rclcpp_action_execute_cancel,
+    action_server_handle);
+}
+
+void TRACEPOINT(
+  fish_rclcpp_action_execute_result,
+  const void * action_server_handle)
+{
+  CONDITIONAL_TP(
+    fish_rclcpp_action_execute_result,
+    action_server_handle);
+}
+
 #ifndef _WIN32
 # pragma GCC diagnostic pop
 #else
PATCH_TT_C
    log "    tracetools.c patched"
}

