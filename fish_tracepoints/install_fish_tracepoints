# ─── Verification ────────────────────────────────────────────────────────────
verify() {
    log ""
    log "=========================================="
    log " FISH Tracepoints Installed"
    log "=========================================="
    log ""
    log "Overlay workspace: $OVERLAY_WS"
    log ""

    local so="$OVERLAY_WS/install/tracetools/lib/libtracetools.so"

    if $DO_ACTION; then
        local action_syms
        action_syms=$(nm -D "$so" 2>/dev/null | grep -c "ros_trace_rclcpp_action_" || true)
        log "Action symbols in libtracetools.so: $action_syms (expected: 4)"
    fi

    if $DO_CLIENT; then
        local client_syms
        client_syms=$(nm -D "$so" 2>/dev/null | grep -c "ros_trace_rclcpp_client_" || true)
        log "Client symbols in libtracetools.so: $client_syms (expected: 2)"
    fi

    if $DO_LINK; then
        local link_syms
        link_syms=$(nm -D "$so" 2>/dev/null | grep -c "ros_trace_fish_" || true)
        log "Link symbols in libtracetools.so: $link_syms (expected: 2)"

        if nm -D "$so" 2>/dev/null | grep -q "__fish_active_callback"; then
            log "Thread-local __fish_active_callback: OK"
        else
            warn "Thread-local __fish_active_callback: NOT FOUND"
        fi
    fi

    if $DO_RCLPY; then
        local rclpy_syms
        rclpy_syms=$(nm -D "$so" 2>/dev/null | grep -c "ros_trace_rclpy_" || true)
        log "rclpy symbols in libtracetools.so: $rclpy_syms (expected: 5)"

        if python3 -c "from rclpy.fish_rclpy_trace import trace_sub_cb; print('  ctypes bridge: OK')" 2>/dev/null; then
            :
        else
            warn "  ctypes bridge: import failed (will work after sourcing overlay)"
        fi
    fi

    # Event count
    set +u && source "$OVERLAY_WS/install/setup.bash" && set -u
    local event_count
    event_count=$(python3 -c "
from tracetools_trace.tools.names import DEFAULT_EVENTS_ROS
print(len(DEFAULT_EVENTS_ROS))
" 2>/dev/null || echo "0")

    local expected=28
    $DO_ACTION && expected=$((expected + 4))
    $DO_RCLPY  && expected=$((expected + 5))
    $DO_CLIENT && expected=$((expected + 2))
    $DO_LINK   && expected=$((expected + 2))
    log "Events in DEFAULT_EVENTS_ROS: $event_count (expected: $expected)"

    if [ "${FISH_SETUP_PARENT:-}" != "1" ]; then
        log ""
        log "Done. Commit this container to bake FISH tracepoints into your image."
    fi
}

# ─── Setup .bashrc ───────────────────────────────────────────────────────────
setup_bashrc() {
    step "Updating .bashrc with overlay source ..."

    local BASHRC="$HOME/.bashrc"
    local MARKER="# FISH_TRACEPOINTS_OVERLAY"
    local SETUP_LINE="source $OVERLAY_WS/install/setup.bash  $MARKER"

    if [ ! -f "$BASHRC" ]; then
        warn "  $BASHRC not found, creating it"
        touch "$BASHRC"
    fi

    # Remove only FISH's own line (identified by marker), leave user's overlays alone
    sed -i "/$MARKER/d" "$BASHRC"

    # Append fresh
    echo "$SETUP_LINE" >> "$BASHRC"
    log "  Added to .bashrc: $SETUP_LINE"
}

