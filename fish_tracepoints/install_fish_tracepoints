# ─── Build tracetools ───────────────────────────────────────────────────────
build_tracetools() {
    step "Building tracetools ..."
    cd "$OVERLAY_WS"

    colcon build \
        --packages-select tracetools \
        --cmake-args -DBUILD_TESTING=OFF \
        2>&1 | tail -5

    # Verify symbols
    local so="$OVERLAY_WS/install/tracetools/lib/libtracetools.so"
    if $DO_ACTION; then
        if nm -D "$so" 2>/dev/null | grep -q "ros_trace_rclcpp_action_server_init"; then
            log "  Action symbols: OK"
        else
            err "  Action symbols: FAILED"
            exit 1
        fi
    fi
    if $DO_RCLPY; then
        if nm -D "$so" 2>/dev/null | grep -q "ros_trace_rclpy_subscription_callback_added"; then
            log "  rclpy symbols: OK"
        else
            err "  rclpy symbols: FAILED"
            exit 1
        fi
    fi
}

