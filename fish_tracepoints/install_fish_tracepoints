# ─── rclpy: ctypes bridge + Python patches ───────────────────────────────────
create_ctypes_bridge() {
    log "  Creating fish_rclpy_trace.py ctypes bridge ..."

    cat > "$RCLPY_DIR/fish_rclpy_trace.py" <<'PYBRIDGE'
"""
FISH rclpy tracepoint bridge.

Calls LTTng tracepoint functions in libtracetools.so via ctypes.
Provides the rclpy callback chain events that rclcpp fires natively
but rclpy does not.

Usage (from rclpy internals):
    from rclpy.fish_rclpy_trace import trace_sub_cb, trace_cb_start, ...
"""
import ctypes
import os

_lib = None
_enabled = False

def _init():
    global _lib, _enabled
    try:
        for path in [
            os.environ.get("FISH_TRACETOOLS_LIB", ""),
            "libtracetools.so",
        ]:
            if path and (os.path.isfile(path) or "/" not in path):
                try:
                    _lib = ctypes.CDLL(path)
                    break
                except OSError:
                    continue
        if _lib is None:
            return

        _lib.ros_trace_compile_status.restype = ctypes.c_bool
        if not _lib.ros_trace_compile_status():
            return

        for name in [
            "ros_trace_fish_rclpy_subscription_callback_added",
            "ros_trace_fish_rclpy_service_callback_added",
            "ros_trace_fish_rclpy_timer_callback_added",
        ]:
            fn = getattr(_lib, name)
            fn.argtypes = [ctypes.c_void_p, ctypes.c_void_p]
            fn.restype = None

        # fish_rclpy_timer_init: (timer_handle, node_handle, period_ns)
        _lib.ros_trace_fish_rclpy_timer_init.argtypes = [
            ctypes.c_void_p, ctypes.c_void_p, ctypes.c_int64]
        _lib.ros_trace_fish_rclpy_timer_init.restype = None

        _lib.ros_trace_fish_rclpy_callback_register.argtypes = [
            ctypes.c_void_p, ctypes.c_char_p]
        _lib.ros_trace_fish_rclpy_callback_register.restype = None

        _lib.ros_trace_callback_start.argtypes = [
            ctypes.c_void_p, ctypes.c_bool]
        _lib.ros_trace_callback_start.restype = None

        _lib.ros_trace_callback_end.argtypes = [ctypes.c_void_p]
        _lib.ros_trace_callback_end.restype = None

        # Client tracepoints
        _lib.ros_trace_fish_rclcpp_client_request_sent.argtypes = [
            ctypes.c_void_p, ctypes.c_int64]
        _lib.ros_trace_fish_rclcpp_client_request_sent.restype = None

        _lib.ros_trace_fish_rclcpp_client_response_received.argtypes = [
            ctypes.c_void_p, ctypes.c_int64, ctypes.c_int]
        _lib.ros_trace_fish_rclcpp_client_response_received.restype = None

        # Link tracepoints (v2)
        try:
            _lib.ros_trace_fish_rclcpp_publish_link.argtypes = [
                ctypes.c_void_p, ctypes.c_void_p]
            _lib.ros_trace_fish_rclcpp_publish_link.restype = None
            _lib.ros_trace_fish_rclcpp_client_link.argtypes = [
                ctypes.c_void_p, ctypes.c_void_p]
            _lib.ros_trace_fish_rclcpp_client_link.restype = None
        except AttributeError:
            pass  # link tracepoints not installed yet

        # Scheduler introspection tracepoints (optional — only if --scheduler installed)
        try:
            _lib.ros_trace_fish_rclcpp_executor_init.argtypes = [
                ctypes.c_void_p, ctypes.c_char_p, ctypes.c_uint32]
            _lib.ros_trace_fish_rclcpp_executor_init.restype = None
            _lib.ros_trace_fish_rclcpp_callback_group_init.argtypes = [
                ctypes.c_void_p, ctypes.c_char_p, ctypes.c_uint8]
            _lib.ros_trace_fish_rclcpp_callback_group_init.restype = None
            _lib.ros_trace_fish_rclcpp_cbgroup_add.argtypes = [
                ctypes.c_void_p, ctypes.c_void_p, ctypes.c_char_p]
            _lib.ros_trace_fish_rclcpp_cbgroup_add.restype = None
            _lib.ros_trace_fish_rclcpp_executor_add_cbgroup.argtypes = [
                ctypes.c_void_p, ctypes.c_void_p, ctypes.c_void_p]
            _lib.ros_trace_fish_rclcpp_executor_add_cbgroup.restype = None
        except AttributeError:
            pass  # scheduler tracepoints not installed

        _enabled = True
    except (OSError, AttributeError):
        _enabled = False

_init()


def _get_symbol(callback):
    sym = getattr(callback, '__qualname__', None)
    mod = getattr(callback, '__module__', None)
    if sym and mod:
        return f"{mod}.{sym}"
    elif sym:
        return sym
    return repr(callback)


def _register(callback):
    if not _enabled:
        return
    cb_id = id(callback)
    symbol = _get_symbol(callback)
    _lib.ros_trace_fish_rclpy_callback_register(
        ctypes.c_void_p(cb_id), symbol.encode('utf-8'))


def trace_sub_cb(sub_handle_ptr, callback):
    if not _enabled:
        return
    cb_id = ctypes.c_void_p(id(callback))
    _lib.ros_trace_fish_rclpy_subscription_callback_added(
        ctypes.c_void_p(sub_handle_ptr), cb_id)
    _register(callback)


def trace_srv_cb(srv_handle_ptr, callback):
    if not _enabled:
        return
    cb_id = ctypes.c_void_p(id(callback))
    _lib.ros_trace_fish_rclpy_service_callback_added(
        ctypes.c_void_p(srv_handle_ptr), cb_id)
    _register(callback)


def trace_tmr_cb(tmr_handle_ptr, callback):
    if not _enabled:
        return
    cb_id = ctypes.c_void_p(id(callback))
    _lib.ros_trace_fish_rclpy_timer_callback_added(
        ctypes.c_void_p(tmr_handle_ptr), cb_id)
    _register(callback)


def trace_tmr_init(tmr_handle_ptr, node_handle_ptr, period_nsec):
    if not _enabled:
        return
    _lib.ros_trace_fish_rclpy_timer_init(
        ctypes.c_void_p(tmr_handle_ptr),
        ctypes.c_void_p(node_handle_ptr),
        ctypes.c_int64(int(period_nsec)))


def trace_cb_start(callback):
    if not _enabled:
        return
    _active_cb.value = id(callback)
    _lib.ros_trace_callback_start(ctypes.c_void_p(id(callback)), False)


def trace_cb_end(callback):
    if not _enabled:
        return
    _lib.ros_trace_callback_end(ctypes.c_void_p(id(callback)))
    _active_cb.value = None


def trace_client_request_sent(client_handle_ptr, sequence_number):
    if not _enabled:
        return
    _lib.ros_trace_fish_rclcpp_client_request_sent(
        ctypes.c_void_p(client_handle_ptr),
        ctypes.c_int64(sequence_number))


def trace_client_response_received(client_handle_ptr, sequence_number, response_type):
    if not _enabled:
        return
    _lib.ros_trace_fish_rclcpp_client_response_received(
        ctypes.c_void_p(client_handle_ptr),
        ctypes.c_int64(sequence_number),
        ctypes.c_int(response_type))


# ── Link tracepoints (v2) ──
import threading
_active_cb = threading.local()


def trace_client_link(client_handle_ptr):
    """Fire fish_rclcpp_client_link — associates client handle to active callback."""
    if not _enabled:
        return
    cb = getattr(_active_cb, 'value', None)
    if cb is not None:
        try:
            _lib.ros_trace_fish_rclcpp_client_link(
                ctypes.c_void_p(client_handle_ptr), ctypes.c_void_p(cb))
        except (OSError, AttributeError):
            pass


def trace_publish_link(publisher_handle_ptr):
    """Fire fish_rclcpp_publish_link — associates publisher handle to active callback."""
    if not _enabled:
        return
    cb = getattr(_active_cb, 'value', None)
    if cb is not None:
        try:
            _lib.ros_trace_fish_rclcpp_publish_link(
                ctypes.c_void_p(publisher_handle_ptr), ctypes.c_void_p(cb))
        except (OSError, AttributeError):
            pass


# ── Scheduler introspection (rclpy-side of the 4 scheduler tracepoints) ──

def _entity_rcl_handle(entity):
    """Best effort to extract an rcl handle pointer from an rclpy entity.

    Subscriptions / Services / Timers / Clients / Guards expose
    `.handle.pointer` (the rcl_*_t address). Waitables and composite
    objects (ActionServer, ActionClient) do not — fall back to id(entity).
    """
    h = getattr(entity, 'handle', None)
    ptr = getattr(h, 'pointer', None) if h is not None else None
    if ptr is None:
        return id(entity)
    return ptr


_ENTITY_KIND = {
    'Subscription': 'sub',
    'Timer':        'tmr',
    'Service':      'srv',
    'Client':       'cli',
    # Everything else (Waitable, GuardCondition, ActionServer, ActionClient,
    # LifecycleService, etc.) collapses to "wait" — matches the C++ side.
}


def trace_executor_init(executor, executor_type, num_threads):
    """Fire fish_rclcpp_executor_init — executor type + thread count."""
    if not _enabled:
        return
    try:
        _lib.ros_trace_fish_rclcpp_executor_init(
            ctypes.c_void_p(id(executor)),
            executor_type.encode('utf-8'),
            ctypes.c_uint32(num_threads))
    except (OSError, AttributeError):
        pass


def trace_cbgroup_init(group, group_type, automatic_add=True):
    """Fire fish_rclcpp_callback_group_init — CG type + automatic_add flag.

    `group_type` is "MutuallyExclusive" or "Reentrant" (match C++ literal
    so the model code does not need to special-case rclpy).
    """
    if not _enabled:
        return
    try:
        _lib.ros_trace_fish_rclcpp_callback_group_init(
            ctypes.c_void_p(id(group)),
            group_type.encode('utf-8'),
            ctypes.c_uint8(1 if automatic_add else 0))
    except (OSError, AttributeError):
        pass


def trace_cbgroup_add(group, entity):
    """Fire fish_rclcpp_cbgroup_add — entity-to-CG association.

    entity_addr is the rcl handle when available, so the event joins
    directly with rcl_*_init tracepoints (same convention as C++ side).
    """
    if not _enabled:
        return
    try:
        handle_ptr = _entity_rcl_handle(entity)
        kind = _ENTITY_KIND.get(type(entity).__name__, 'wait')
        _lib.ros_trace_fish_rclcpp_cbgroup_add(
            ctypes.c_void_p(id(group)),
            ctypes.c_void_p(handle_ptr),
            kind.encode('utf-8'))
    except (OSError, AttributeError):
        pass


# rclpy.spin_once / spin_until_future_complete do add_node → spin →
# remove_node every iteration. Without dedup, trace_executor_add_cbgroup
# would fire thousands of times per second and overflow LTTng buffers.
_SEEN_EXEC_CG = set()


def trace_executor_add_cbgroup(executor, group, node):
    """Fire fish_rclcpp_executor_add_cbgroup — executor ↔ CG association.

    Deduplicates on (executor, group, node) id triple: each logical
    association is reported once per process lifetime, matching the C++
    side where add_callback_group_to_map can only succeed once.
    """
    if not _enabled:
        return
    key = (id(executor), id(group), id(node))
    if key in _SEEN_EXEC_CG:
        return
    _SEEN_EXEC_CG.add(key)
    try:
        node_ptr = _entity_rcl_handle(node)
        _lib.ros_trace_fish_rclcpp_executor_add_cbgroup(
            ctypes.c_void_p(id(executor)),
            ctypes.c_void_p(id(group)),
            ctypes.c_void_p(node_ptr))
    except (OSError, AttributeError):
        pass
PYBRIDGE

    log "    Created $RCLPY_DIR/fish_rclpy_trace.py"
}

