# ─── Patch names.py ──────────────────────────────────────────────────────────
patch_names_py() {
    step "Patching tracetools_trace event list (names.py) ..."

    NAMES_PY=$(python3 -c "
import tracetools_trace.tools.names as m
import os
print(os.path.abspath(m.__file__))
")

    if [ ! -f "$NAMES_PY" ]; then
        err "Could not find tracetools_trace names.py at $NAMES_PY"
        exit 1
    fi

    python3 <<PATCHNAMES
import re

do_action    = $( $DO_ACTION    && echo "True" || echo "False" )
do_rclpy     = $( $DO_RCLPY     && echo "True" || echo "False" )
do_client    = $( $DO_CLIENT    && echo "True" || echo "False" )
do_link      = $( $DO_LINK      && echo "True" || echo "False" )
do_scheduler = $( $DO_SCHEDULER && echo "True" || echo "False" )

# Idempotent regeneration of DEFAULT_EVENTS_ROS: keep stock entries
# (tracepoints.X), discard ALL "ros2:..." entries (which are FISH additions —
# possibly stale from a pre-rename install), then re-emit a fresh FISH section
# based on the current --flags. Running twice gives the same result.

with open("$NAMES_PY") as f:
    content = f.read()

m = re.search(r'(DEFAULT_EVENTS_ROS\s*=\s*\[\n)(.*?)(^\])',
              content, re.MULTILINE | re.DOTALL)
if not m:
    raise SystemExit("Could not find DEFAULT_EVENTS_ROS list in names.py")

prefix, body, suffix = m.group(1), m.group(2), m.group(3)

# Keep only stock entries (lines that use the tracepoints.X form)
stock_lines = []
for line in body.split("\n"):
    s = line.strip().rstrip(",")
    if not s:
        continue
    if s.startswith("tracepoints."):
        stock_lines.append("    " + s + ",")
    # everything else (ros2:fish_*, ros2:rclpy_*, etc.) is dropped

# Re-emit FISH section based on --flags
fish_groups = []
if do_action:
    fish_groups.append([
        "fish_rclcpp_action_server_init",
        "fish_rclcpp_action_execute_goal",
        "fish_rclcpp_action_execute_cancel",
        "fish_rclcpp_action_execute_result",
    ])
if do_rclpy:
    fish_groups.append([
        "fish_rclpy_subscription_callback_added",
        "fish_rclpy_service_callback_added",
        "fish_rclpy_timer_callback_added",
        "fish_rclpy_timer_init",
        "fish_rclpy_callback_register",
    ])
if do_client:
    fish_groups.append([
        "fish_rclcpp_client_request_sent",
        "fish_rclcpp_client_response_received",
        "fish_rclcpp_timer_init",
    ])
if do_link:
    fish_groups.append([
        "fish_rclcpp_publish_link",
        "fish_rclcpp_client_link",
        "fish_rclcpp_receive_link",
    ])
if do_scheduler:
    fish_groups.append([
        "fish_rclcpp_executor_init",
        "fish_rclcpp_callback_group_init",
        "fish_rclcpp_cbgroup_add",
        "fish_rclcpp_executor_add_cbgroup",
    ])

fish_lines = []
for group in fish_groups:
    for evt in group:
        fish_lines.append('    "ros2:' + evt + '",')

new_body = "\n".join(stock_lines + fish_lines) + "\n"
new_block = prefix + new_body + suffix
new_content = content[:m.start()] + new_block + content[m.end():]

if new_content != content:
    with open("$NAMES_PY", "w") as f:
        f.write(new_content)
    print("  names.py regenerated: " + str(len(stock_lines)) + " stock + "
          + str(len(fish_lines)) + " fish entries")
else:
    print("  names.py up-to-date (" + str(len(stock_lines)) + " stock + "
          + str(len(fish_lines)) + " fish)")

PATCHNAMES
}

# ─── Verification ────────────────────────────────────────────────────────────
verify() {
    log ""
    log "=========================================="
    log " FISH Tracepoints Installed"
    log "=========================================="
    log ""
    log "Overlay workspace: $OVERLAY_WS"
    log ""

    local so="$OVERLAY_WS/install/tracetools/lib/libtracetools.so"

    if $DO_ACTION; then
        local action_syms
        action_syms=$(nm -D "$so" 2>/dev/null | grep -c "ros_trace_fish_rclcpp_action_" || true)
        log "Action symbols in libtracetools.so: $action_syms (expected: 4)"
    fi

    if $DO_CLIENT; then
        local client_syms
        client_syms=$(nm -D "$so" 2>/dev/null | grep -c "ros_trace_fish_rclcpp_client_request_sent\|ros_trace_fish_rclcpp_client_response_received\|ros_trace_fish_rclcpp_timer_init" || true)
        log "Client symbols in libtracetools.so: $client_syms (expected: 3)"
    fi

    if $DO_LINK; then
        local link_syms
        link_syms=$(nm -D "$so" 2>/dev/null | grep -c "ros_trace_fish_rclcpp_publish_link\|ros_trace_fish_rclcpp_client_link" || true)
        log "Link symbols in libtracetools.so: $link_syms (expected: 2)"

        if nm -D "$so" 2>/dev/null | grep -q "__fish_active_callback"; then
            log "Thread-local __fish_active_callback: OK"
        else
            warn "Thread-local __fish_active_callback: NOT FOUND"
        fi
    fi

    if $DO_SCHEDULER; then
        local sched_syms
        sched_syms=$(nm -D "$so" 2>/dev/null | grep -c "ros_trace_fish_rclcpp_executor_init\|ros_trace_fish_rclcpp_callback_group_init\|ros_trace_fish_rclcpp_cbgroup_add\|ros_trace_fish_rclcpp_executor_add_cbgroup" || true)
        log "Scheduler symbols in libtracetools.so: $sched_syms (expected: 4)"

        local rclcpp_so="$OVERLAY_WS/install/rclcpp/lib/librclcpp.so"
        if [ -f "$rclcpp_so" ] && nm -D "$rclcpp_so" 2>/dev/null | grep -q "fish_rclcpp_executor_init\|fish_rclcpp_callback_group_init"; then
            log "rclcpp scheduler tracepoints: linked"
        elif [ -f "$rclcpp_so" ]; then
            warn "rclcpp scheduler tracepoints: symbols not found in librclcpp.so"
        fi
    fi

    if $DO_RCLPY; then
        local rclpy_syms
        rclpy_syms=$(nm -D "$so" 2>/dev/null | grep -c "ros_trace_fish_rclpy_" || true)
        log "rclpy symbols in libtracetools.so: $rclpy_syms (expected: 5)"

        if python3 -c "from rclpy.fish_rclpy_trace import trace_sub_cb; print('  ctypes bridge: OK')" 2>/dev/null; then
            :
        else
            warn "  ctypes bridge: import failed (will work after sourcing overlay)"
        fi
    fi

    # Event count
    set +u && source "$OVERLAY_WS/install/setup.bash" && set -u
    local event_count
    event_count=$(python3 -c "
from tracetools_trace.tools.names import DEFAULT_EVENTS_ROS
print(len(DEFAULT_EVENTS_ROS))
" 2>/dev/null || echo "0")

    local expected=28
    $DO_ACTION    && expected=$((expected + 4))
    $DO_RCLPY     && expected=$((expected + 5))
    $DO_CLIENT    && expected=$((expected + 3))
    $DO_LINK      && expected=$((expected + 2))
    $DO_SCHEDULER && expected=$((expected + 4))
    log "Events in DEFAULT_EVENTS_ROS: $event_count (expected: $expected)"

    if [ "${FISH_SETUP_PARENT:-}" != "1" ]; then
        log ""
        log "Done. Commit this container to bake FISH tracepoints into your image."
    fi
}

# ─── Setup .bashrc ───────────────────────────────────────────────────────────
setup_bashrc() {
    step "Updating .bashrc with overlay source ..."

    local BASHRC="$HOME/.bashrc"
    local MARKER="# FISH_TRACEPOINTS_OVERLAY"
    local SETUP_LINE="source $OVERLAY_WS/install/setup.bash  $MARKER"

    if [ ! -f "$BASHRC" ]; then
        warn "  $BASHRC not found, creating it"
        touch "$BASHRC"
    fi

    # Remove only FISH's own line (identified by marker), leave user's overlays alone
    sed -i "/$MARKER/d" "$BASHRC"

    # Append fresh
    echo "$SETUP_LINE" >> "$BASHRC"
    log "  Added to .bashrc: $SETUP_LINE"
}

# ═════════════════════════════════════════════════════════════════════════════
# Main
# ═════════════════════════════════════════════════════════════════════════════
main() {
    log "FISH Tracepoint Installer"
    log "  action:    $DO_ACTION"
    log "  rclpy:     $DO_RCLPY"
    log "  client:    $DO_CLIENT"
    log "  link:      $DO_LINK"
    log "  scheduler: $DO_SCHEDULER"
    log ""

    preflight_checks
    create_workspace
    clone_repos
    copy_sources

    # Patch tracetools C source (action first, then rclpy, then client, then link, then scheduler)
    step "Patching tracetools C source ..."
    $DO_ACTION    && patch_tracetools_action
    $DO_RCLPY     && patch_tracetools_rclpy
    $DO_CLIENT    && patch_tracetools_client
    $DO_LINK      && patch_tracetools_link
    $DO_SCHEDULER && patch_tracetools_scheduler

    build_tracetools

    # Feature-specific post-build work.
    # Order: rcl (no dep on rclcpp) → rclcpp_action (depends on rclcpp) → rclcpp (client + scheduler share one build)
    $DO_LINK      && patch_and_build_rcl
    $DO_ACTION    && patch_and_build_rclcpp_action
    $DO_CLIENT    && patch_and_build_rclcpp_client
    $DO_SCHEDULER && patch_and_build_rclcpp_scheduler
    # rclcpp intra-process publisher patch — same fish_rclcpp_publish_link
    # tracepoint, fires for same-process pub→sub that bypasses rcl entirely.
    $DO_LINK      && patch_rclcpp_publisher_intra
    # NITROS patch: only relevant when --link is on (fires fish_rclcpp_publish_link).
    # Always runs but skips gracefully if isaac_ros_nitros source isn't present.
    $DO_LINK      && patch_and_build_isaac_ros_nitros
    if $DO_RCLPY; then
        install_rclpy_tracepoints
    fi

    patch_names_py
    setup_bashrc
    verify
}

main "$@"
